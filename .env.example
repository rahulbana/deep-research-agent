# ======================================================================
# Deep Agent — environment configuration
# Copy to `.env` and fill in your secrets.  All values are optional
# unless the corresponding provider is selected.
# ======================================================================

# --- LLM (switchable) ---------------------------------------------------
# provider: openai | anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- LLM fine-grained control -------------------------------------------
# Optional cheaper model used by FAST-tier agents (e.g. reflection).
# LLM_FAST_MODEL=gpt-4o-mini
# Per-agent model overrides (JSON): roles = planner|reflection|fact_checker|writer
# LLM_AGENT_MODELS={"writer":"gpt-4o","reflection":"gpt-4o-mini"}
# LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
# LLM_SEED=42

# --- LLM response cache -------------------------------------------------
# backend: none | memory | sqlite  (sqlite dedupes identical calls across runs)
LLM_CACHE_BACKEND=sqlite
LLM_CACHE_PATH=deep_agent_llm_cache.sqlite

# --- Context budgeting (input-token control) ----------------------------
MAX_CONTEXT_CHARS=24000
PER_SOURCE_CHARS=1500

# --- Search (switchable) ------------------------------------------------
# provider: tavily | serper
SEARCH_PROVIDER=tavily
SEARCH_MAX_RESULTS=6
TAVILY_API_KEY=tvly-...
# SERPER_API_KEY=...

# --- Research loop ------------------------------------------------------
MAX_RESEARCH_ITERATIONS=3
SCRAPE_TIMEOUT_SECONDS=20
SCRAPE_MAX_CONCURRENCY=5

# --- Scraper politeness -------------------------------------------------
SCRAPE_USER_AGENT=DeepAgent/0.1 (+https://example.com/bot)
RESPECT_ROBOTS=true
SCRAPE_DELAY_SECONDS=1.0

# --- CLI ----------------------------------------------------------------
# Show live per-node progress (stream) vs. a single silent invoke.
STREAM_PROGRESS=true

# --- Celery -------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Run scraping tasks inline (no worker/broker needed) when true.
CELERY_TASK_ALWAYS_EAGER=true

# --- Checkpointing ------------------------------------------------------
# backend: none | memory | sqlite  (sqlite is resumable across runs)
CHECKPOINT_BACKEND=memory
CHECKPOINT_DB=deep_agent_checkpoints.sqlite

# --- Observability (Langfuse) -------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Logging ------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs

# --- Output -------------------------------------------------------------
OUTPUT_DIR=docs

